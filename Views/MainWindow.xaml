<Window x:Class="PasswordManager.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="パスワードマネージャー"
        Width="900" Height="560"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header: ファイル名 + 保存ボタン -->
        <Border Grid.Row="0" Background="#F0F0F0" BorderBrush="#CCCCCC" BorderThickness="0,0,0,1">
            <DockPanel Margin="10,6">
                <Button DockPanel.Dock="Right"
                        Content="保存"
                        Width="72" Height="28"
                        Command="{Binding SaveCommand}"/>
                <TextBlock VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="#555555">
                    <Run Text="ファイル: "/>
                    <Run Text="{Binding CurrentFileName}" FontWeight="SemiBold" Foreground="#222222"/>
                </TextBlock>
            </DockPanel>
        </Border>

        <!-- DataGrid -->
        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Entries}"
                  SelectedItem="{Binding SelectedEntry}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  SelectionMode="Single"
                  Margin="0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Site" Binding="{Binding Site, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                <DataGridTextColumn Header="ユーザー名" Binding="{Binding Username, UpdateSourceTrigger=PropertyChanged}" Width="160"/>
                <DataGridTextColumn Header="パスワード" Binding="{Binding Password, UpdateSourceTrigger=PropertyChanged}" Width="160"/>
                <DataGridTextColumn Header="備考" Binding="{Binding Notes, UpdateSourceTrigger=PropertyChanged}" Width="200"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Loading overlay -->
        <Grid Grid.Row="1"
              Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
              Background="#BBFFFFFF">
            <TextBlock Text="処理中..."
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       FontSize="16" Foreground="#555555"/>
        </Grid>

        <!-- Footer: 追加/削除ボタン -->
        <Border Grid.Row="2" Background="#F0F0F0" BorderBrush="#CCCCCC" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" Margin="10,6">
                <Button Content="追加"
                        Width="72" Height="28"
                        Margin="0,0,8,0"
                        Command="{Binding AddCommand}"/>
                <Button Content="削除"
                        Width="72" Height="28"
                        Command="{Binding DeleteCommand}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
